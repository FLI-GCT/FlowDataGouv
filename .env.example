# Required: Mistral API key (https://console.mistral.ai/)
MISTRAL_API_KEY=your-mistral-api-key

# Optional: Mistral model for enrichment (default: mistral-small-latest)
# MISTRAL_MODEL=mistral-small-latest

# Optional: Secret to protect the sync API endpoint
# SYNC_SECRET=your-secret-here

# Optional: Rate limit per IP per day (default: 20)
# RATE_LIMIT_MAX=20

# Optional: Maximum download cache size in GB (default: 10)
# DOWNLOAD_CACHE_MAX_GB=10
