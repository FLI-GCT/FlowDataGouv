# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep .example files for documentation)
.env
.env.local
.env.production
.env.*.local

# server credentials (never commit)
.server-info

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data files (generated, too large for git)
/data/

# mcp server
mcp/node_modules
mcp/dist

# meilisearch (local dev binary + data)
meilisearch.exe
/meili-data/

# claude code (local config, not for sharing)
.claude/
